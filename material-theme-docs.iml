      <excludeFolder url="file://$MODULE_DIR$/download" />
      <excludeFolder url="file://$MODULE_DIR$/jekyllbuild" />
      <excludeFolder url="file://$MODULE_DIR$/js" />
    </content>
    <orderEntry type="inheritedJdk" />
    <orderEntry type="sourceFolder" forTests="false" />
  </component>
</module>